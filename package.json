{
  "name": "jira-hot-linker",
  "version": "2.3.0-beta",
  "description": "Jira HotLinker, quick access to Jira metadata when hovering over ticket numbers!",
  "scripts": {
    "analyze": "webpack --mode=production --bail --profile --json > stats.json || webpack-bundle-analyzer stats.json",
    "build": "node scripts/build-extension-and-reload.js",
    "build:active-extension": "node scripts/build-extension-and-reload.js",
    "build:bundle-only": "webpack --mode=development",
    "dev": "webpack --watch --mode=development",
    "lint": "eslint . --ext .js,.jsx",
    "lint:fix": "eslint . --ext .js,.jsx --fix",
    "pwcli": ".agents/skills/openai-skills-playwright/scripts/playwright_cli.sh",
    "validate:manifest": "node scripts/validate-manifest.js",
    "test:e2e:startup-smoke": "node scripts/playwright/check-extension-startup.js",
    "test": "npm run test:e2e",
    "test:e2e": "npm run test:e2e:mock-edge",
    "test:e2e:all": "node scripts/playwright/run-all-suites.js",
    "test:e2e:mock-edge": "npm exec -- playwright test --project=mock-edge --project=mock-popup",
    "test:e2e:public-smoke": "npm exec -- playwright test --project=public-smoke",
    "test:e2e:live-authenticated": "node scripts/playwright/run-live-authenticated.js",
    "test:e2e:extension": "npm run test:e2e:live-authenticated",
    "test:e2e:public": "npm run test:e2e:public-smoke",
    "test:e2e:live": "npm run test:e2e:live-authenticated",
    "test:e2e:auth:live": "node scripts/playwright/capture-live-auth.js",
    "screenshots:marketing": "node scripts/playwright/capture-marketing-screenshots.js",
    "test:e2e:headed": "npm exec -- playwright test --headed",
    "test:e2e:ui": "npm exec -- playwright test --ui",
    "test:e2e:show-report": "npm exec -- playwright show-report tests/output/playwright/report",
    "test:e2e:reset-report-data": "node scripts/playwright/reset-reports.js",
    "release:check": "node scripts/release-check.js",
    "tldr:setup": "node scripts/setup-llm-tldr.js",
    "tldr:code": "node scripts/llm-tldr.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dgebaei/Jira-Hot-Linker.git"
  },
  "author": "Willem",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/dgebaei/Jira-Hot-Linker/issues"
  },
  "homepage": "https://github.com/dgebaei/Jira-Hot-Linker#readme",
  "devDependencies": {
    "@babel/core": "7.17.5",
    "@babel/preset-env": "7.16.11",
    "@babel/preset-react": "7.16.7",
    "@playwright/test": "^1.58.2",
    "babel-loader": "8.2.3",
    "css-loader": "6.6.0",
    "escape-string-regexp": "5.0.0",
    "eslint": "8.9.0",
    "eslint-plugin-react": "7.28.0",
    "jquery": "3.6.0",
    "jquery-ui": "^1.14.1",
    "lodash": "4.17.23",
    "mustache": "4.2.0",
    "playwright": "^1.58.2",
    "react": "17.0.2",
    "react-dom": "17.0.2",
    "sass": "1.89.2",
    "sass-loader": "16.0.5",
    "style-loader": "3.3.1",
    "webpack": "5.105.4",
    "webpack-bundle-analyzer": "4.5.0",
    "webpack-cli": "4.9.2"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2"
  }
}
