{
  "name": "jira-hot-linker",
  "version": "2.0.0",
  "description": "Jira HotLinker, quick access to Jira metadata when hovering over ticket numbers!",
  "main": " ",
  "scripts": {
    "analyze": "webpack --mode=production --bail --profile --json > stats.json || webpack-bundle-analyzer stats.json",
    "build": "webpack --mode=development",
    "dev": "webpack --watch --mode=development",
    "pwcli": ".agents/skills/openai-skills-playwright/scripts/playwright_cli.sh",
    "test": "npm run test:e2e",
    "test:e2e": "npm run test:e2e:extension",
    "test:e2e:all": "node scripts/playwright/run-with-blob.js",
    "test:e2e:extension": "node scripts/playwright/run-with-blob.js --project=extension",
    "test:e2e:public": "node scripts/playwright/run-with-blob.js --project=public-jira",
    "test:e2e:live": "node scripts/playwright/run-with-blob.js --project=live-jira",
    "test:e2e:auth:live": "node scripts/playwright/capture-live-auth.js",
    "test:e2e:headed": "node scripts/playwright/run-with-blob.js --headed",
    "test:e2e:ui": "npm exec -- playwright test --ui",
    "test:e2e:merge-report": "node scripts/playwright/merge-reports.js",
    "test:e2e:show-report": "npm exec -- playwright show-report tests/output/playwright/report",
    "test:e2e:reset-report-data": "node scripts/playwright/reset-reports.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/helmus/Jira-Hot-Linker.git"
  },
  "author": "Willem",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/helmus/Jira-Hot-Linker/issues"
  },
  "homepage": "https://github.com/helmus/Jira-Hot-Linker#readme",
  "devDependencies": {
    "@babel/cli": "7.17.3",
    "@babel/core": "7.17.5",
    "@babel/preset-env": "7.16.11",
    "@babel/preset-react": "7.16.7",
    "@playwright/test": "^1.58.2",
    "babel-eslint": "10.0.2",
    "babel-loader": "8.2.3",
    "bluebird": "3.7.2",
    "clipboard": "2.0.10",
    "css-loader": "6.6.0",
    "escape-string-regexp": "5.0.0",
    "eslint": "8.9.0",
    "eslint-plugin-react": "7.28.0",
    "jquery": "3.6.0",
    "jquery-ui": "1.14.1",
    "lodash": "4.17.23",
    "mustache": "4.2.0",
    "playwright": "^1.58.2",
    "react": "17.0.2",
    "react-dom": "17.0.2",
    "sass": "1.89.2",
    "sass-loader": "16.0.5",
    "style-loader": "3.3.1",
    "webpack": "5.105.4",
    "webpack-bundle-analyzer": "4.5.0",
    "webpack-cli": "4.9.2"
  }
}
